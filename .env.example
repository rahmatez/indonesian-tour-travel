# ─── App ───────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Indonesian Tour Travel

# ─── Database (Fase 2) ─────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/indonesian_tour_travel
DIRECT_URL=postgresql://user:pass@host:5432/indonesian_tour_travel

# ─── Redis (Fase 2) ────────────────────────────
REDIS_URL=redis://...

# ─── Auth (Fase 2) ─────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ─── Cloudflare R2 (Fase 2) ────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=indonesian-tour-travel-media
R2_PUBLIC_URL=https://media.indonesiantourtravel.com

# ─── Stripe (Fase 2) ───────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Midtrans (Fase 2) ─────────────────────────
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# ─── OpenAI (Fase 3) ───────────────────────────
OPENAI_API_KEY=

# ─── WhatsApp Business API (Fase 2) ──────────────
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ─── Email (Fase 2) ────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=hello@indonesiantourtravel.com
